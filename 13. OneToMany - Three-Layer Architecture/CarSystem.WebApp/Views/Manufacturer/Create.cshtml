@{
    ViewData["Title"] = "Add Manufacturer";
}

<div class="container mt-5">
    <h2>Add New Manufacturer</h2>
    <hr />

    <form asp-action="Create" method="post" class="col-md-6">
        <div class="mb-3">
            <label class="form-label">Manufacturer Name</label>
            <input name="name" class="form-control" placeholder="e.g. Toyota" required />
        </div>
        <div class="mb-3">
            <label class="form-label">Country</label>
            <input name="country" class="form-control" placeholder="e.g. Japan" required />
        </div>

        <button type="submit" class="btn btn-primary">Save Brand</button>
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>
